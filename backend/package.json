{
  "name": "proofsnap-backend",
  "version": "1.0.0",
  "description": "Lean serverless backend for AI analysis and encrypted backup.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "deploy": "serverless deploy",
    "offline": "serverless offline --stage dev"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.916.0",
    "@aws-sdk/lib-dynamodb": "^3.916.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "serverless-http": "^4.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "serverless": "^4.24.0",
    "serverless-offline": "^14.4.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
