APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rampready
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
NWS_USER_AGENT=(rampready.local, contact@example.com)
ENABLE_OPEN_METEO=false
OPEN_METEO_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHAT_ENABLED=true
CHAT_CANDIDATE_LIMIT=5
CHAT_SOURCE_TIMEOUT_SECONDS=8
CHAT_OPENAI_TIMEOUT_SECONDS=20
CHAT_USE_OPENAI_IN_TESTS=false
DEFAULT_REGION=florida-gulf
CORS_ORIGINS=http://localhost:5173,http://localhost:19006
ADMIN_EMAIL=admin@rampready.local
ADMIN_PASSWORD=admin123!
API_BASE_URL=http://localhost:8000
